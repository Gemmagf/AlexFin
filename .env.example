# AlexFin — Variables d'entorn (copia aquest fitxer a .env per ús local)
# A Render.com: Environment > Add Environment Variable

# ── Autenticació ──────────────────────────────
AUTH_USER=alex
AUTH_PASS=canvia_aquesta_contrasenya

# ── Seguretat Flask ───────────────────────────
# Genera un valor aleatori fort: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=canvia_aquest_valor_secret

# ── Servidor ──────────────────────────────────
PORT=8050
DASH_DEBUG=false
